).place(x=500, y=400, width=300, height=40)

tipo = Entry(janela, font=("Arial", 15))
tipo.place(x=50, y=450, width=200, height=40)

evo = Entry(janela, font=("Arial", 15))
evo.place(x=600, y=450, width=150, height=40)

Button(janela, text="Procurar", font=("Arial", 15), command=procurar).place(
    x=350, y=520, width=100, height=40
)

janela.mainloop()
